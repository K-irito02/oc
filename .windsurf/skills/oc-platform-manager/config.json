{
  "name": "oc-platform-manager",
  "version": "1.4.0",
  "lastUpdated": "2026-03-04",
  "description": "OC Platform 项目管理技能 - 自动化检查/执行项目依赖、后端/前端构建及运行，支持状态日志记录（包含 lint 和 build 详细输出）",
  "triggers": [
    "启动项目",
    "停止项目",
    "重启项目",
    "start project",
    "stop project",
    "restart project",
    "运行项目",
    "关闭项目",
    "检查项目状态",
    "project status"
  ],
  "workingDirectory": "e:/oc/oc-platform",
  "services": {
    "frontend": {
      "port": 5173,
      "command": "npm run dev",
      "cwd": "oc-platform-web"
    },
    "backend": {
      "port": 8081,
      "command": "java -jar oc-platform-app/target/oc-platform-app-1.0.0-SNAPSHOT.jar --spring.profiles.active=dev"
    },
    "postgres": {
      "port": 5433,
      "container": "oc-dev-postgres"
    },
    "redis": {
      "port": 6380,
      "container": "oc-dev-redis"
    },
    "minio": {
      "port": 9000,
      "consolePort": 9001,
      "container": "oc-dev-minio"
    }
  },
  "credentials": {
    "postgres": {
      "user": "oc_user",
      "password": "3143285505",
      "database": "oc_platform"
    },
    "redis": {
      "password": "3143285505"
    },
    "minio": {
      "accessKey": "minioadmin",
      "secretKey": "minioadmin"
    },
    "testAccounts": {
      "admin": {
        "email": "admin@ocplatform.com",
        "password": "Admin@123456"
      },
      "user": {
        "email": "zhangsan@example.com",
        "password": "Test@123456"
      }
    }
  },
  "logging": {
    "enabled": true,
    "logDirectory": "e:/oc/logs",
    "logFiles": {
      "docker": "docker-status.log",
      "backend": "backend-status.log",
      "frontend": "frontend-status.log"
    },
    "logLevel": "INFO",
    "includeTimestamps": true,
    "includeProcessIds": true,
    "includePerformanceMetrics": true,
    "overwriteMode": true,
    "description": "每次启动/停止时覆盖现有日志文件，保持日志文件最新状态"
  },
  "relatedWorkflows": [
    "commit-env-state",
    "commit-project-code",
    "start-project",
    "stop-project"
  ]
}
